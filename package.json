{
  "name": "iptv-playlist-generator",
  "version": "2.0.0",
  "private": true,
  "description": "Simple Apple style IPTV playlist generator with Netlify, Electron and Capacitor support.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-sw-version.mjs && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "vite",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "win:start": "electron .",
    "win:build": "npm run build && electron-builder --win portable nsis"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.10"
  },
  "build": {
    "appId": "com.bucala.iptvplaylistgen",
    "productName": "IPTV Playlist Generator",
    "files": [
      "index.html",
      "manifest.json",
      "sw.js",
      "icons/**/*",
      "electron/**/*",
      "capacitor.config.json",
      "dist/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    }
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "type": "module"
}
